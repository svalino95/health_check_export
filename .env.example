# Rename this file to .env and fill in your real credentials
# NEVER commit .env to Git

FALCON_CLIENT_ID=test
FALCON_CLIENT_SECRET=test

# Customer name (displayed in the HTML report header)
CS_CLIENT_NAME=COMPANY

# Base URL — use us-2 for this tenant
CS_BASE_URL=https://api.us-2.crowdstrike.com

# Child CID (only if MSSP and you want to target a child tenant)
# FALCON_MEMBER_CID=

# NG SIEM — manually fill from falcon.us-2.crowdstrike.com/data-connectors/
# (NG SIEM search API requires special enablement - contact your TAM)
CS_NGSIEM_LIMIT_GB=10
CS_NGSIEM_AVG_GB=0.76
CS_NGSIEM_TODAY_MB=1.1

# Connectors: "Name:Status:Ingest24h" separated by commas
CS_NGSIEM_CONNECTORS=Netskope SSE:Active:8.55MB,Entra ID:Error:0B,Windows and AD:Idle:0B,VSQualys:Pending:0B,Test-Forti:Pending:0B

# Output file names
CS_OUT_XLSX=health_check.xlsx
CS_OUT_HTML=health_check.html
