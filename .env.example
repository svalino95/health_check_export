# Renombrá este archivo a .env y completá con tus credenciales reales
# NUNCA subas .env a Git

FALCON_CLIENT_ID=test
FALCON_CLIENT_SECRET=test

# Nombre del cliente (aparece en el header del reporte HTML)
CS_CLIENT_NAME=COMPANY

# URL base — us-2 para este tenant
CS_BASE_URL=https://api.us-2.crowdstrike.com

# CID hijo (solo si es MSSP y querés apuntar a un tenant hijo)
# FALCON_MEMBER_CID=

# NG SIEM — completar a mano desde falcon.us-2.crowdstrike.com/data-connectors/
# (El API de búsqueda NG SIEM necesita habilitación especial - contactar al TAM)
CS_NGSIEM_LIMIT_GB=10
CS_NGSIEM_AVG_GB=0.76
CS_NGSIEM_TODAY_MB=1.1
# Conectores: "Nombre:Estado:Ingest24h" separados por coma
CS_NGSIEM_CONNECTORS=Netskope SSE:Active:8.55MB,Entra ID:Error:0B,Windows and AD:Idle:0B,VSQualys:Pending:0B,Test-Forti:Pending:0B

# Nombres de los archivos de salida
CS_OUT_XLSX=health_check.xlsx
CS_OUT_HTML=health_check.html
